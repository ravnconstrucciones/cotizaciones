NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# Lectura automática de comprobantes (foto/audio) en Caja — elegí proveedor con CASHFLOW_EXTRACT_PROVIDER.
# gemini: imágenes + audio (recomendado si usás Google AI). También: GOOGLE_API_KEY, GOOGLE_AI_API_KEY.
GEMINI_API_KEY=
# Opcional: modelo (por defecto gemini-2.5-flash). Si Google avisa que el modelo no está disponible, elegí uno en AI Studio.
# GEMINI_MODEL=gemini-2.5-flash-lite

# claude: solo imágenes (Anthropic). El audio siempre usa Gemini si hay GEMINI_API_KEY.
ANTHROPIC_API_KEY=
# Opcional: modelo (por defecto claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# auto (defecto): si hay GEMINI_API_KEY, usa Gemini para fotos; si no, Claude si hay ANTHROPIC_API_KEY.
# Forzar: CASHFLOW_EXTRACT_PROVIDER=gemini | claude | auto
CASHFLOW_EXTRACT_PROVIDER=auto
