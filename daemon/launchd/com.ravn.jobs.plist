    <string>/Users/ezeotero/.ravn-jobs/logs/launchd.err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/ezeotero/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/ezeotero</string>
    </dict>
</dict>
</plist>
